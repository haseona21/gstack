#!/usr/bin/env bash
# gstack-config — read/write ~/.gstack/config.yaml
#
# Usage:
#   gstack-config get <key>          — read a config value
#   gstack-config set <key> <value>  — write a config value
#   gstack-config list               — show all config
#
# Env overrides (for testing):
#   GSTACK_STATE_DIR  — override ~/.gstack state directory
set -euo pipefail

STATE_DIR="${GSTACK_STATE_DIR:-$HOME/.gstack}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: gstack-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: gstack-config set <key> <value>}"
    VALUE="${3:?Usage: gstack-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      sed -i '' "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  snooze)
    SNOOZE_FILE="$STATE_DIR/update-snoozed"
    if [ ! -f "$SNOOZE_FILE" ]; then
      echo "No update snoozed."
    else
      read -r SV SL SE < "$SNOOZE_FILE"
      case "${SL:-}" in 1) DUR=86400 ;; 2) DUR=172800 ;; *) DUR=604800 ;; esac
      LEFT=$(( SE + DUR - $(date +%s) ))
      [ "$LEFT" -gt 0 ] \
        && echo "v$SV snoozed (level $SL), ~$(( LEFT / 3600 ))h left" \
        || echo "v$SV snooze expired"
    fi
    ;;
  *)
    echo "Usage: gstack-config {get|set|list|snooze} [key] [value]"
    exit 1
    ;;
esac
